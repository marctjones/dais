{
  "version": 2,
  "name": "dais-vercel",
  "builds": [
    {
      "src": "functions/webfinger/Cargo.toml",
      "use": "@vercel/rust",
      "config": {
        "runtime": "rust@1.75.0"
      }
    },
    {
      "src": "functions/actor/Cargo.toml",
      "use": "@vercel/rust",
      "config": {
        "runtime": "rust@1.75.0"
      }
    },
    {
      "src": "functions/inbox/Cargo.toml",
      "use": "@vercel/rust",
      "config": {
        "runtime": "rust@1.75.0"
      }
    },
    {
      "src": "functions/outbox/Cargo.toml",
      "use": "@vercel/rust",
      "config": {
        "runtime": "rust@1.75.0"
      }
    },
    {
      "src": "functions/delivery-queue/Cargo.toml",
      "use": "@vercel/rust",
      "config": {
        "runtime": "rust@1.75.0"
      }
    },
    {
      "src": "functions/auth/Cargo.toml",
      "use": "@vercel/rust",
      "config": {
        "runtime": "rust@1.75.0"
      }
    },
    {
      "src": "functions/pds/Cargo.toml",
      "use": "@vercel/rust",
      "config": {
        "runtime": "rust@1.75.0"
      }
    },
    {
      "src": "functions/router/Cargo.toml",
      "use": "@vercel/rust",
      "config": {
        "runtime": "rust@1.75.0"
      }
    },
    {
      "src": "functions/landing/Cargo.toml",
      "use": "@vercel/rust",
      "config": {
        "runtime": "rust@1.75.0"
      }
    }
  ],
  "routes": [
    {
      "src": "/.well-known/webfinger",
      "dest": "/functions/webfinger"
    },
    {
      "src": "/users/([^/]+)",
      "dest": "/functions/actor"
    },
    {
      "src": "/users/([^/]+)/followers",
      "dest": "/functions/actor"
    },
    {
      "src": "/users/([^/]+)/following",
      "dest": "/functions/actor"
    },
    {
      "src": "/users/([^/]+)/inbox",
      "dest": "/functions/inbox"
    },
    {
      "src": "/users/([^/]+)/outbox",
      "dest": "/functions/outbox"
    },
    {
      "src": "/queue/process",
      "dest": "/functions/delivery-queue"
    },
    {
      "src": "/auth/(.*)",
      "dest": "/functions/auth"
    },
    {
      "src": "/xrpc/(.*)",
      "dest": "/functions/pds"
    },
    {
      "src": "/(.*)",
      "dest": "/functions/landing"
    }
  ],
  "env": {
    "DATABASE_URL": "@database-url",
    "BLOB_READ_WRITE_TOKEN": "@blob-token",
    "UPSTASH_REDIS_URL": "@redis-url",
    "UPSTASH_REDIS_TOKEN": "@redis-token",
    "THEME": "cat-light"
  },
  "crons": [
    {
      "path": "/queue/process",
      "schedule": "*/5 * * * *"
    }
  ]
}
