import {
    Button,
    CheckBox,
    ComboBox,
    LineEdit,
    ScrollView,
    TextEdit,
} from "std-widgets.slint";

export struct NavItem {
    id: string,
    title: string,
    count: string,
    count-tone: string,
    active: bool,
}

export struct UiRow {
    id: string,
    kind: string,
    avatar: string,
    avatar-url: string,
    title: string,
    subtitle: string,
    detail: string,
    meta: string,
    chip: string,
    tone: string,
    primary: string,
    secondary: string,
}

export struct AccountRow {
    id: string,
    title: string,
    subtitle: string,
    active: bool,
    token: bool,
    can_delete: bool,
}

component Chip inherits Rectangle {
    in property <string> label;
    in property <string> tone;
    callback activate();
    border-radius: 6px;
    border-width: 1px;
    border-color: tone == "danger" ? #c23b3b : tone == "warn" ? #a76f14 : tone == "ok" ? #1f7a45 : #b8c0ca;
    background: tone == "danger" ? #fff0f0 : tone == "warn" ? #fff6df : tone == "ok" ? #eef9f1 : #f4f6f8;
    min-height: 24px;
    horizontal-stretch: 0;
    accessible-role: button;
    accessible-label: root.label;
    accessible-description: "Open visibility and audience details";
    accessible-action-default => {
        root.activate();
    }

    Text {
        text: root.label;
        color: root.tone == "danger" ? #7b1c1c : root.tone == "warn" ? #6d470b : root.tone == "ok" ? #145a32 : #39424e;
        font-size: 12px;
        horizontal-alignment: center;
        vertical-alignment: center;
        x: 10px;
        width: root.width - 20px;
        height: root.height;
    }

    TouchArea {
        clicked => {
            root.activate();
        }
    }
}

component MetaPill inherits Rectangle {
    in property <string> label;
    in property <string> tone;

    height: 20px;
    border-radius: 5px;
    border-width: 1px;
    border-color: tone == "danger" ? #f0b8b8 : tone == "warn" ? #ead09a : tone == "ok" ? #bfe1cd : #d7dee8;
    background: tone == "danger" ? #fff6f6 : tone == "warn" ? #fffbeb : tone == "ok" ? #f1fbf5 : #f7f9fc;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;

        Text {
            text: root.label;
            color: root.tone == "danger" ? #7b1c1c : root.tone == "warn" ? #714a08 : root.tone == "ok" ? #1f5f3b : #536175;
            font-size: 11px;
            font-weight: 700;
            overflow: elide;
            vertical-alignment: center;
        }
    }
}

component SegmentOption inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    in property <string> tone;
    callback activate();

    height: 32px;
    min-width: 104px;
    border-radius: 6px;
    border-width: 1px;
    border-color: selected ? (tone == "danger" ? #b42318 : tone == "warn" ? #b7791f : #2f6fae) : #cfd8e3;
    background: selected ? (tone == "danger" ? #fff0f0 : tone == "warn" ? #fffbeb : #eaf3ff) : #ffffff;
    accessible-role: button;
    accessible-label: selected ? label + " selected" : label;
    accessible-description: "Choose compose audience or delivery route";
    accessible-action-default => {
        root.activate();
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;

        Rectangle {
            width: 14px;
            height: 14px;
            border-radius: 7px;
            border-width: 1px;
            border-color: root.selected ? (root.tone == "danger" ? #b42318 : root.tone == "warn" ? #b7791f : #2f6fae) : #aab5c3;
            background: root.selected ? (root.tone == "danger" ? #b42318 : root.tone == "warn" ? #b7791f : #2f6fae) : #ffffff;
        }

        Text {
            text: root.label;
            color: root.selected ? (root.tone == "danger" ? #7b1c1c : root.tone == "warn" ? #714a08 : #174a7e) : #2f3948;
            font-size: 12px;
            font-weight: root.selected ? 800 : 600;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    TouchArea {
        clicked => {
            root.activate();
        }
    }
}

component ToolbarCommandButton inherits Rectangle {
    in property <string> symbol;
    in property <string> label;
    in property <string> description;
    callback activate();

    width: 84px;
    height: 46px;
    border-radius: 6px;
    border-width: 1px;
    border-color: #cfd8e3;
    background: touch-area.pressed ? #dbeafe : touch-area.has-hover ? #f2f7ff : #ffffff;
    accessible-role: button;
    accessible-label: label;
    accessible-description: description;
    accessible-action-default => {
        root.activate();
    }

    VerticalLayout {
        padding-top: root.symbol == "" ? 0px : 5px;
        padding-bottom: root.symbol == "" ? 0px : 5px;
        spacing: root.symbol == "" ? 0px : 1px;

        if root.symbol != "" : Text {
            text: root.symbol;
            color: #174a7e;
            font-size: 16px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            text: root.label;
            color: #2f3948;
            font-size: root.symbol == "" ? 12px : 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    touch-area := TouchArea {
        clicked => {
            root.activate();
        }
    }
}

component DisclosureToggle inherits Rectangle {
    in property <bool> expanded;
    callback activate();

    width: 20px;
    height: 20px;
    border-radius: 4px;
    background: touch-area.has-hover ? #eef3f8 : transparent;
    accessible-role: button;
    accessible-label: expanded ? "Collapse section" : "Expand section";
    accessible-description: "Show or hide inspector section detail";
    accessible-action-default => {
        root.activate();
    }

    Text {
        text: root.expanded ? "v" : ">";
        color: #5d6878;
        font-size: 12px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch-area := TouchArea {
        clicked => {
            root.activate();
        }
    }
}

component SourceButton inherits Rectangle {
    in property <NavItem> item;
    callback activate(string);

    height: 34px;
    border-radius: 6px;
    background: item.active ? #e8edf5 : transparent;
    border-width: item.active ? 1px : 0px;
    border-color: #cdd6e2;
    accessible-role: button;
    accessible-label: root.item.title;
    accessible-description: root.item.count == "" ? root.item.title : root.item.title + " " + root.item.count;
    accessible-action-default => {
        root.activate(root.item.id);
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 8px;
        spacing: 8px;

        Text {
            text: item.title;
            color: item.active ? #172033 : #344055;
            font-size: 13px;
            font-weight: item.active ? 700 : 500;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }

        if item.count != "" : Rectangle {
            min-width: 26px;
            height: 20px;
            border-radius: 10px;
            background: item.count-tone == "attention" ? #fff0d6 : item.count-tone == "owner" ? #eaf6ee : item.active ? #d3dceb : #eef1f4;
            border-width: item.count-tone == "attention" ? 1px : 0px;
            border-color: #e0a12b;

            Text {
                text: item.count;
                color: item.count-tone == "attention" ? #6d470b : item.count-tone == "owner" ? #1f5f3b : #334155;
                font-size: 11px;
                font-weight: item.count-tone == "attention" ? 800 : 500;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    TouchArea {
        clicked => {
            root.activate(root.item.id);
        }
    }
}

component RowCard inherits Rectangle {
    in property <UiRow> entry;
    in property <bool> selected;
    property <bool> is-post: entry.kind == "post";
    property <bool> is-notification: entry.kind == "notification";
    property <bool> is-message: entry.kind == "message";
    property <bool> is-conversation: entry.kind == "conversation";
    property <bool> is-relationship: entry.kind == "relationship";
    property <bool> is-reading-source: entry.chip == "Watch" || entry.chip == "Source";
    property <bool> has-actions: entry.primary != "" || entry.secondary != "";
    property <bool> show-actions: selected && has-actions;
    callback open(string);
    callback action(string, string);

    height: root.is-post ? (root.show-actions ? 168px : 128px) : root.is-notification ? (root.show-actions ? 154px : 126px) : root.is-message || root.is-conversation ? (root.show-actions ? 126px : 104px) : root.is-relationship ? (root.show-actions ? 126px : 104px) : (root.show-actions ? 136px : 108px);
    vertical-stretch: 0;
    border-radius: root.is-post ? 8px : 7px;
    border-width: selected ? 1px : 0px;
    border-color: #5f94ca;
    background: selected ? #eef6ff : root.is-notification && entry.tone == "warn" ? #fffaf0 : root.is-conversation ? #fbfcff : #ffffff;
    accessible-role: list-item;
    accessible-label: root.entry.title;
    accessible-description: root.entry.subtitle + " " + root.entry.meta + " " + root.entry.detail;
    accessible-action-default => {
        root.open(root.entry.id);
    }

    Rectangle {
        x: 0px;
        y: 0px;
        width: selected ? 4px : 3px;
        height: root.height;
        border-radius: 3px;
        background: root.entry.tone == "danger" ? #c23b3b : root.entry.tone == "warn" ? #c98a18 : root.entry.tone == "ok" ? #23814b : #7c8da3;
    }

    VerticalLayout {
        padding: root.is-post ? 14px : 12px;
        spacing: root.is-post ? 8px : root.is-message || root.is-conversation ? 6px : 7px;

        HorizontalLayout {
            spacing: 10px;

            if root.is-post || root.is-relationship || root.is-message || root.is-conversation : Rectangle {
                width: root.is-post ? 38px : 30px;
                height: root.is-post ? 38px : 30px;
                border-radius: root.is-post ? 19px : 15px;
                background: root.entry.avatar-url != "" ? #dbeafe : root.is-relationship ? #eef9f1 : root.is-message || root.is-conversation ? #eff6ff : #e8edf5;
                border-width: 1px;
                border-color: root.entry.avatar-url != "" ? #7aa5d8 : root.is-relationship ? #b9dec4 : root.is-message || root.is-conversation ? #bfd7f2 : #cdd6e2;

                Text {
                    text: root.entry.avatar;
                    color: root.is-relationship ? #145a32 : root.is-message || root.is-conversation ? #174a7e : #27415f;
                    font-size: root.is-post ? 12px : 11px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                if root.entry.avatar-url != "" : Rectangle {
                    x: parent.width - 10px;
                    y: parent.height - 10px;
                    width: 9px;
                    height: 9px;
                    border-radius: 5px;
                    background: #23814b;
                    border-width: 1px;
                    border-color: #ffffff;
                }
            }

            VerticalLayout {
                spacing: 3px;
                horizontal-stretch: 1;

                Text {
                    text: root.entry.title;
                    color: #121820;
                    font-size: 14px;
                    font-weight: 700;
                    overflow: elide;
                }

                Text {
                    text: root.entry.subtitle;
                    color: #5c6674;
                    font-size: 12px;
                    overflow: elide;
                }
            }

            if root.entry.chip != "" : Chip {
                label: root.entry.chip;
                tone: root.entry.tone;
                activate => {
                    root.open(root.entry.id);
                }
            }
        }

        if root.entry.meta != "" && !(root.is-post || root.is-message || root.is-conversation) : MetaPill {
            label: root.entry.meta;
            tone: root.entry.tone;
        }

        if root.entry.meta != "" && (root.is-post || root.is-message || root.is-conversation) : Text {
            text: root.entry.meta;
            color: root.entry.tone == "warn" ? #8a5a0a : root.entry.tone == "danger" ? #8a1f1f : #3f6b50;
            font-size: 12px;
            font-weight: 700;
            overflow: elide;
        }

        Text {
            text: root.entry.detail;
            color: #27313f;
            font-size: root.is-post || root.is-message || root.is-conversation ? 14px : 13px;
            wrap: word-wrap;
            max-height: root.is-post ? 64px : root.is-message || root.is-conversation ? 42px : 48px;
            overflow: elide;
        }

        if root.show-actions : HorizontalLayout {
            height: 34px;
            spacing: 8px;
            if root.entry.primary != "" : Button {
                height: 34px;
                text: root.entry.primary;
                clicked => {
                    root.action(root.entry.id, root.entry.primary);
                }
            }
            if root.entry.secondary != "" : Button {
                height: 34px;
                text: root.entry.secondary;
                clicked => {
                    root.action(root.entry.id, root.entry.secondary);
                }
            }
            if (root.is-post || root.is-notification) && root.entry.secondary == "" : Button {
                height: 34px;
                text: root.is-post && !root.is-reading-source ? "Audience" : "Details";
                clicked => {
                    root.open(root.entry.id);
                }
            }
        }
    }
}

component InspectorRow inherits Rectangle {
    in property <UiRow> entry;
    property <bool> expanded: true;
    property <bool> has-actions: root.entry.primary != "" || root.entry.secondary != "";
    callback action(string, string);

    height: root.expanded ? (root.has-actions ? 118px : 86px) : 42px;
    vertical-stretch: 0;
    border-radius: 5px;
    background: root.expanded ? #ffffff : #f8fafc;
    border-width: 1px;
    border-color: #e3e7ee;
    accessible-role: button;
    accessible-label: root.entry.title;
    accessible-description: root.expanded ? root.entry.detail : "Collapsed inspector section";
    accessible-action-default => {
        root.expanded = !root.expanded;
    }

    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 7px;

        HorizontalLayout {
            spacing: 8px;

            DisclosureToggle {
                expanded: root.expanded;
                activate => {
                    root.expanded = !root.expanded;
                }
            }

            Text {
                text: root.entry.title;
                font-size: 13px;
                font-weight: 700;
                color: #152033;
                horizontal-stretch: 1;
                overflow: elide;
            }
            if root.entry.chip != "" : Chip {
                label: root.entry.chip;
                tone: root.entry.tone;
            }
        }

        if root.expanded : Text {
                text: root.entry.detail;
                font-size: 12px;
                color: #445064;
                wrap: word-wrap;
                max-height: root.has-actions ? 36px : 42px;
                overflow: elide;
            }

        if root.expanded && root.has-actions : HorizontalLayout {
                height: 32px;
                spacing: 8px;
                if root.entry.primary != "" : Button {
                    height: 32px;
                    text: root.entry.primary;
                    clicked => {
                        root.action(root.entry.id, root.entry.primary);
                    }
                }
                if root.entry.secondary != "" : Button {
                    height: 32px;
                    text: root.entry.secondary;
                    clicked => {
                        root.action(root.entry.id, root.entry.secondary);
                    }
                }
            }
    }
}

export component MainWindow inherits Window {
    title: "Dais Desk";
    preferred-width: 1180px;
    preferred-height: 760px;
    min-width: 920px;
    min-height: 620px;
    background: #eef1f5;

    in property <[NavItem]> mode-nav;
    in property <[NavItem]> screen-nav;
    in property <[UiRow]> rows;
    in property <[UiRow]> inspector-rows;
    in property <[AccountRow]> accounts;
    in property <[string]> account-options;
    in property <int> active-account-index;
    in property <string> active-account-label;
    in property <string> active-account-url;
    in property <string> active-mode;
    in property <string> active-screen;
    in property <string> selected-row;
    in property <string> inspector-title;
    in property <bool> inspector-visible;
    in-out property <bool> inspector-open;
    in property <string> window-title;
    in property <string> window-subtitle;
    in property <string> attention-summary;
    in property <string> privacy-status;
    in property <string> status-message;
    in-out property <string> command-text;
    in-out property <string> compose-text;
    in-out property <string> compose-recipients;
    in-out property <string> compose-audience-list;
    in-out property <string> compose-media-description;
    in-out property <bool> compose-encrypt;
    in property <string> compose-visibility;
    in property <string> compose-protocol;
    in property <string> compose-warning;
    in property <string> compose-audience-summary;
    in property <string> compose-primary-action-text;
    in property <bool> compose-can-send;
    in-out property <string> account-label;
    in-out property <string> account-url;
    in-out property <string> account-token;
    in-out property <string> search-scope;
    in-out property <string> search-provider;
    in-out property <string> search-type;
    in-out property <string> search-servers;
    in-out property <string> search-sort;
    in-out property <string> search-since;
    in-out property <string> search-until;
    in-out property <string> search-author;
    in-out property <string> search-mentions;
    in-out property <string> search-lang;
    in-out property <string> search-domain;
    in-out property <string> search-url;
    in-out property <string> search-tags;
    in-out property <bool> search-confirm-public-sensitive;
    in-out property <string> source-type;
    in-out property <string> source-url;
    in-out property <string> source-title;
    in-out property <string> source-cadence;
    in-out property <string> watch-type;
    in-out property <string> watch-target;
    in-out property <string> watch-title;
    in-out property <string> watch-cadence;
    in-out property <string> bundle-follow-target;
    in-out property <string> profile-actor-type;
    in-out property <string> profile-display-name;
    in-out property <string> profile-summary;
    in-out property <string> profile-icon;
    in-out property <string> profile-image;
    in property <string> profile-preview;
    in-out property <string> audience-id;
    in-out property <string> audience-name;
    in-out property <string> audience-description;
    in-out property <string> audience-group-type;
    in-out property <string> audience-membership-visibility;
    in-out property <string> audience-posting-policy;
    in-out property <string> audience-categories;
    in-out property <string> audience-members;
    in-out property <string> moderation-reply-policy;
    in-out property <bool> moderation-ai-enabled;
    in-out property <string> moderation-ai-model;
    in-out property <string> moderation-ai-budget;
    in-out property <string> moderation-block-actor;
    in-out property <string> moderation-block-domain;
    in-out property <string> moderation-block-reason;
    in-out property <string> moderation-allow-host;
    in-out property <string> moderation-allow-note;
    in-out property <string> settings-default-visibility;
    in-out property <string> settings-default-protocol;
    in-out property <bool> settings-require-authorized-fetch;
    in-out property <bool> settings-manually-approves-followers;
    in-out property <bool> settings-closed-network;
    in-out property <string> media-file-path;
    in-out property <string> media-type;
    in-out property <string> media-description;
    in-out property <string> media-access;
    in-out property <string> media-expires-seconds;
    in-out property <bool> media-authorized-fetch;
    in-out property <string> media-revoke-url;

    callback select-mode(string);
    callback select-screen(string);
    callback select-row(string);
    callback row-action(string, string);
    callback refresh();
    callback run-command(string);
    callback run-filtered-search(string, string, string, string, string, string, string, string, string, string, string, string, string, string, bool);
    callback add-source(string, string, string, string);
    callback add-watch(string, string, string, string);
    callback save-source-bundle(string, string, string, string, string, string, string);
    callback preview-profile(string, string, string, string, string);
    callback save-profile(string, string, string, string, string);
    callback save-audience(string, string, string, string, string, string, string, string);
    callback delete-audience(string);
    callback save-moderation(string, bool, string, string);
    callback save-settings(string, string, bool, bool, bool);
    callback block-actor(string, string);
    callback block-domain(string, string);
    callback allow-host(string, string);
    callback disallow-host(string);
    callback choose-media-file();
    callback upload-media(string, string, string, string, string, bool);
    callback revoke-media(string);
    callback save-account(string, string, string);
    callback switch-account(string);
    callback switch-account-option(string);
    callback delete-account(string);
    callback compose-send();
    callback compose-set-visibility(string);
    callback compose-set-protocol(string);
    callback move-selected-row-up();
    callback move-selected-row-down();
    callback move-selected-row-home();
    callback move-selected-row-end();
    callback activate-selected-row();
    callback select-row-by-prefix(string);
    callback toggle-inspector();

    forward-focus: command-key-handler;

    command-key-handler := FocusScope {
        focus-on-click: false;

        KeyBinding {
            keys: @keys(Control + "1");
            activated => {
                root.select-mode("home");
            }
        }

        KeyBinding {
            keys: @keys(Meta + "1");
            activated => {
                root.select-mode("home");
            }
        }

        KeyBinding {
            keys: @keys(Control + "2");
            activated => {
                root.select-mode("people");
            }
        }

        KeyBinding {
            keys: @keys(Meta + "2");
            activated => {
                root.select-mode("people");
            }
        }

        KeyBinding {
            keys: @keys(Control + "3");
            activated => {
                root.select-screen("compose");
            }
        }

        KeyBinding {
            keys: @keys(Meta + "3");
            activated => {
                root.select-screen("compose");
            }
        }

        KeyBinding {
            keys: @keys(Control + "f");
            activated => {
                root.select-mode("people");
            }
        }

        KeyBinding {
            keys: @keys(Meta + "f");
            activated => {
                root.select-mode("people");
            }
        }

        KeyBinding {
            keys: @keys(Control + "n");
            activated => {
                root.select-screen("compose");
            }
        }

        KeyBinding {
            keys: @keys(Meta + "n");
            activated => {
                root.select-screen("compose");
            }
        }

        KeyBinding {
            keys: @keys(Control + "r");
            activated => {
                root.refresh();
            }
        }

        KeyBinding {
            keys: @keys(Meta + "r");
            activated => {
                root.refresh();
            }
        }

        KeyBinding {
            keys: @keys(J);
            activated => {
                root.move-selected-row-down();
            }
        }

        KeyBinding {
            keys: @keys(K);
            activated => {
                root.move-selected-row-up();
            }
        }

        KeyBinding {
            keys: @keys(G);
            activated => {
                root.move-selected-row-home();
            }
        }

        KeyBinding {
            keys: @keys(Home);
            activated => {
                root.move-selected-row-home();
            }
        }

        KeyBinding {
            keys: @keys(End);
            activated => {
                root.move-selected-row-end();
            }
        }

        KeyBinding {
            keys: @keys(Return);
            activated => {
                root.activate-selected-row();
            }
        }

        key-pressed(event) => {
            if (event.text != "") {
                root.select-row-by-prefix(event.text);
            }
            reject
        }

        HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 232px;
            background: #f6f7f9;
            border-width: 1px;
            border-color: #d7dde6;

            VerticalLayout {
                padding: 12px;
                spacing: 10px;

                Text {
                    text: "Dais Desk";
                    font-size: 18px;
                    font-weight: 800;
                    color: #101828;
                }

                Text {
                    text: root.privacy-status;
                    font-size: 12px;
                    color: #536175;
                    wrap: word-wrap;
                }

                Rectangle {
                    height: 1px;
                    background: #d7dde6;
                }

                for item in mode-nav : SourceButton {
                    item: item;
                    activate(id) => {
                        root.select-mode(id);
                    }
                }

                Rectangle {
                    height: 1px;
                    background: #d7dde6;
                }

                Text {
                    text: "Views";
                    font-size: 11px;
                    color: #687386;
                    font-weight: 700;
                }

                ScrollView {
                    vertical-stretch: 1;
                    viewport-height: 470px;
                    VerticalLayout {
                        spacing: 4px;
                        for item in screen-nav : SourceButton {
                            item: item;
                            activate(id) => {
                                root.select-screen(id);
                            }
                        }
                    }
                }
            }
        }

        VerticalLayout {
            spacing: 0px;
            horizontal-stretch: 1;

            Rectangle {
                height: 68px;
                background: #ffffff;
                border-width: 1px;
                border-color: #d7dde6;

                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 16px;
                    spacing: 10px;

                    LineEdit {
                        text <=> root.command-text;
                        placeholder-text: "Search people or posts";
                        horizontal-stretch: 1;
                        accepted => {
                            root.run-command(root.command-text);
                        }
                    }

                    VerticalLayout {
                        width: 220px;
                        padding-top: 7px;
                        padding-bottom: 5px;
                        spacing: 2px;
                        Text {
                            text: "Account";
                            color: #344055;
                            font-size: 11px;
                            font-weight: 700;
                            overflow: elide;
                        }
                        ComboBox {
                            model: root.account-options;
                            current-index: root.active-account-index;
                            selected(option) => {
                                root.switch-account-option(option);
                            }
                        }
                    }

                    ToolbarCommandButton {
                        symbol: "";
                        label: "Find";
                        description: "Run the command or search text";
                        activate => {
                            root.run-command(root.command-text);
                        }
                    }

                    ToolbarCommandButton {
                        symbol: "";
                        label: "Compose";
                        description: "Write a new post";
                        activate => {
                            root.select-screen("compose");
                        }
                    }

                    ToolbarCommandButton {
                        symbol: "";
                        label: "Refresh";
                        description: "Refresh posts and conversations";
                        activate => {
                            root.refresh();
                        }
                    }
                }
            }

            HorizontalLayout {
                spacing: 0px;
                vertical-stretch: 1;

                Rectangle {
                    background: #fdfefe;
                    horizontal-stretch: 1;

                    VerticalLayout {
                        padding: 16px;
                        spacing: 10px;

                        HorizontalLayout {
                            spacing: 12px;

                            VerticalLayout {
                                spacing: 2px;
                                horizontal-stretch: 1;
                                Text {
                                    text: root.window-title;
                                    color: #101828;
                                    font-size: 20px;
                                    font-weight: 800;
                                    overflow: elide;
                                }
                                Text {
                                    text: root.window-subtitle;
                                    color: #5b6676;
                                    font-size: 12px;
                                    overflow: elide;
                                }
                            }

                            Chip {
                                label: root.attention-summary;
                                tone: root.attention-summary == "No new replies" ? "ok" : "warn";
                            }
                        }

                        if root.active-screen == "compose" : Rectangle {
                            height: 292px;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: #ccd6e3;
                            background: #fbfdff;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 7px;

                                HorizontalLayout {
                                    height: 34px;
                                    spacing: 8px;
                                    Text {
                                        text: "Compose";
                                        font-size: 15px;
                                        font-weight: 800;
                                        color: #111827;
                                        horizontal-stretch: 1;
                                        vertical-alignment: center;
                                    }
                                    Button {
                                        text: "Save draft";
                                        clicked => {
                                            root.row-action("compose:privacy", "Save draft");
                                        }
                                    }
                                    Button {
                                        text: root.compose-primary-action-text;
                                        enabled: root.compose-can-send;
                                        clicked => {
                                            root.compose-send();
                                        }
                                    }
                                }

                                TextEdit {
                                    text <=> root.compose-text;
                                    height: 92px;
                                }

                                VerticalLayout {
                                    spacing: 5px;

                                    HorizontalLayout {
                                        spacing: 8px;
                                        Text {
                                            text: "Audience";
                                            width: 72px;
                                            color: #344055;
                                            font-size: 12px;
                                            font-weight: 800;
                                            vertical-alignment: center;
                                        }
                                        SegmentOption {
                                            label: "Known people";
                                            selected: root.compose-visibility == "followers";
                                            tone: "ok";
                                            activate => { root.compose-set-visibility("followers"); }
                                        }
                                        SegmentOption {
                                            label: "Direct";
                                            selected: root.compose-visibility == "direct";
                                            tone: "ok";
                                            activate => { root.compose-set-visibility("direct"); }
                                        }
                                        SegmentOption {
                                            label: "Public";
                                            selected: root.compose-visibility == "public";
                                            tone: "danger";
                                            activate => { root.compose-set-visibility("public"); }
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: 8px;
                                        Text {
                                            text: "Route";
                                            width: 72px;
                                            color: #344055;
                                            font-size: 12px;
                                            font-weight: 800;
                                            vertical-alignment: center;
                                        }
                                        SegmentOption {
                                            label: "ActivityPub";
                                            selected: root.compose-protocol == "activitypub";
                                            tone: "ok";
                                            activate => { root.compose-set-protocol("activitypub"); }
                                        }
                                        SegmentOption {
                                            label: "Both";
                                            selected: root.compose-protocol == "both";
                                            tone: root.compose-visibility == "public" ? "danger" : "warn";
                                            activate => { root.compose-set-protocol("both"); }
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 8px;
                                    LineEdit {
                                        text <=> root.compose-recipients;
                                        placeholder-text: "Direct recipients";
                                        horizontal-stretch: 1;
                                    }
                                    LineEdit {
                                        text <=> root.compose-audience-list;
                                        placeholder-text: "Audience group";
                                        horizontal-stretch: 1;
                                    }
                                    CheckBox {
                                        text: "Encrypt";
                                        checked <=> root.compose-encrypt;
                                    }
                                }

                                LineEdit {
                                    text <=> root.compose-media-description;
                                    placeholder-text: "Media alt text / sensitivity note";
                                }

                                Rectangle {
                                    height: 42px;
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: root.compose-visibility == "public" ? #d8b4b4 : #d9dee6;
                                    background: root.compose-visibility == "public" ? #fff7f7 : #ffffff;

                                    VerticalLayout {
                                        padding: 7px;
                                        spacing: 2px;
                                        Text {
                                            text: root.compose-audience-summary;
                                            color: root.compose-visibility == "public" ? #7b1c1c : #27415f;
                                            font-size: 11px;
                                            font-weight: 700;
                                            overflow: elide;
                                        }
                                        Text {
                                            text: root.compose-warning;
                                            color: root.compose-warning == "Ready to send privately." ? #1f7a45 : #8a4d0a;
                                            font-size: 11px;
                                            overflow: elide;
                                        }
                                    }
                                }
                            }
                        }

                        ScrollView {
                            vertical-stretch: 1;
                            VerticalLayout {
                                spacing: 10px;
                                for row in rows : RowCard {
                                    entry: row;
                                    selected: row.id == root.selected-row;
                                    open(id) => {
                                        root.select-row(id);
                                    }
                                    action(id, action) => {
                                        root.row-action(id, action);
                                    }
                                }
                            }
                        }

                        Text {
                            text: root.status-message;
                            color: #536175;
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                    }
                }

                if root.inspector-visible && !root.inspector-open : Rectangle {
                    width: 42px;
                    background: #f7f9fc;
                    border-width: 1px;
                    border-color: #d7dde6;

                    VerticalLayout {
                        padding: 6px;
                        spacing: 8px;

                        Button {
                            text: "Details";
                            clicked => {
                                root.toggle-inspector();
                            }
                        }
                    }
                }

                if root.inspector-visible && root.inspector-open : Rectangle {
                    width: root.active-screen == "compose" || root.active-screen == "find" ? 332px : 300px;
                    background: #f7f9fc;
                    border-width: 1px;
                    border-color: #d7dde6;

                    VerticalLayout {
                        padding: 14px;
                        spacing: 10px;

                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: root.inspector-title;
                                font-size: 16px;
                                font-weight: 800;
                                color: #101828;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }
                            Button {
                                text: "Hide";
                                clicked => {
                                    root.toggle-inspector();
                                }
                            }
                        }

                        Text {
                            text: root.active-screen == "compose" ? "Recipients, media, and final audience checks." : root.active-screen == "find" ? "Discovery filters are here when you need them." : "Context and secondary actions for the selected item.";
                            font-size: 12px;
                            color: #5b6676;
                            wrap: word-wrap;
                        }

                                if root.active-screen == "find" : Rectangle {
                                    min-height: 224px;
                                    border-radius: 7px;
                                    border-width: 1px;
                                    border-color: #d9dee6;
                                    background: #ffffff;

                            VerticalLayout {
                                padding: 10px;
                                spacing: 7px;
                                Text { text: "Find people and sources"; font-weight: 800; font-size: 13px; color: #172033; }
                                HorizontalLayout {
                                    spacing: 6px;
                                    LineEdit { text <=> root.search-scope; placeholder-text: "private or public"; horizontal-stretch: 1; }
                                    LineEdit { text <=> root.search-provider; placeholder-text: "network"; horizontal-stretch: 1; }
                                }
                                HorizontalLayout {
                                    spacing: 6px;
                                    LineEdit { text <=> root.search-type; placeholder-text: "people/posts"; horizontal-stretch: 1; }
                                    LineEdit { text <=> root.search-sort; placeholder-text: "recent/relevant"; horizontal-stretch: 1; }
                                }
                                LineEdit { text <=> root.search-author; placeholder-text: "handle, URL, or name"; }
                                LineEdit { text <=> root.search-url; placeholder-text: "source URL"; }
                                CheckBox {
                                    text: "Allow broad public search";
                                    checked <=> root.search-confirm-public-sensitive;
                                }
                                Button {
                                    text: "Search";
                                    clicked => {
                                        root.run-filtered-search(root.command-text, root.search-scope, root.search-provider, root.search-type, root.search-servers, root.search-sort, root.search-since, root.search-until, root.search-author, root.search-mentions, root.search-lang, root.search-domain, root.search-url, root.search-tags, root.search-confirm-public-sensitive);
                                    }
                                }
                                Rectangle { height: 1px; background: #e5e9f0; }
                                Text { text: "Advanced filters"; font-weight: 800; font-size: 12px; color: #4b5565; }
                                HorizontalLayout {
                                    spacing: 6px;
                                    LineEdit { text <=> root.search-lang; placeholder-text: "lang"; horizontal-stretch: 1; }
                                    LineEdit { text <=> root.search-domain; placeholder-text: "domain"; horizontal-stretch: 1; }
                                }
                                HorizontalLayout {
                                    spacing: 6px;
                                    LineEdit { text <=> root.search-since; placeholder-text: "since"; horizontal-stretch: 1; }
                                    LineEdit { text <=> root.search-until; placeholder-text: "until"; horizontal-stretch: 1; }
                                }
                                LineEdit { text <=> root.search-mentions; placeholder-text: "mentions"; }
                                LineEdit { text <=> root.search-servers; placeholder-text: "servers, comma separated"; }
                                LineEdit { text <=> root.search-tags; placeholder-text: "tags, comma separated"; }
                            }
                        }

                        if root.active-screen == "compose" : Rectangle {
                            height: root.media-file-path == "" && root.media-revoke-url == "" ? 110px : 244px;
                            border-radius: 7px;
                            border-width: 1px;
                            border-color: #d9dee6;
                            background: #ffffff;

                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 7px;
                                    Text { text: "Media attachment"; font-weight: 800; font-size: 13px; color: #172033; }
                                if root.media-file-path == "" : HorizontalLayout {
                                    height: 34px;
                                    spacing: 6px;
                                    LineEdit { text <=> root.media-file-path; placeholder-text: "Local file path"; horizontal-stretch: 1; height: 34px; }
                                    Button {
                                        height: 34px;
                                        text: "Choose file";
                                        clicked => {
                                            root.choose-media-file();
                                        }
                                    }
                                }
                                if root.media-file-path != "" : HorizontalLayout {
                                    height: 34px;
                                    spacing: 6px;
                                    LineEdit { text <=> root.media-file-path; placeholder-text: "Local file path"; horizontal-stretch: 1; height: 34px; }
                                    Button {
                                        height: 34px;
                                        text: "Choose file";
                                        clicked => {
                                            root.choose-media-file();
                                        }
                                    }
                                }
                                if root.media-file-path != "" : HorizontalLayout {
                                    spacing: 6px;
                                    LineEdit { text <=> root.media-type; placeholder-text: "media type"; horizontal-stretch: 1; }
                                    LineEdit { text <=> root.media-access; placeholder-text: "access"; horizontal-stretch: 1; }
                                }
                                if root.media-file-path != "" : LineEdit { text <=> root.media-description; placeholder-text: "alt text / description"; }
                                if root.media-file-path != "" : HorizontalLayout {
                                    spacing: 6px;
                                    LineEdit { text <=> root.media-expires-seconds; placeholder-text: "expires seconds"; horizontal-stretch: 1; }
                                    CheckBox { text: "Auth fetch"; checked <=> root.media-authorized-fetch; }
                                }
                                if root.media-file-path != "" : Button {
                                    text: "Upload and attach";
                                    clicked => {
                                        root.upload-media(root.media-file-path, root.media-type, root.media-description, root.media-access, root.media-expires-seconds, root.media-authorized-fetch);
                                    }
                                }
                                if root.media-revoke-url != "" : LineEdit { text <=> root.media-revoke-url; placeholder-text: "Uploaded media URL to revoke"; }
                                if root.media-revoke-url != "" : Button {
                                    text: "Revoke media";
                                    clicked => {
                                        root.revoke-media(root.media-revoke-url);
                                    }
                                }
                            }
                        }

                        if root.active-screen == "watches" : Rectangle {
                            min-height: 252px;
                            border-radius: 7px;
                            border-width: 1px;
                            border-color: #d9dee6;
                            background: #ffffff;

                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 7px;
                                    Text { text: "Add source or Watch"; font-weight: 800; font-size: 13px; color: #172033; }
                                    HorizontalLayout {
                                    spacing: 6px;
                                    LineEdit { text <=> root.source-type; placeholder-text: "rss | atom | api"; horizontal-stretch: 1; }
                                    LineEdit { text <=> root.source-cadence; placeholder-text: "minutes"; width: 70px; }
                                }
                                LineEdit { text <=> root.source-url; placeholder-text: "Source URL"; }
                                LineEdit { text <=> root.source-title; placeholder-text: "Source title"; }
                                Button {
                                    text: "Add source";
                                    clicked => {
                                        root.add-source(root.source-type, root.source-url, root.source-title, root.source-cadence);
                                    }
                                }
                                HorizontalLayout {
                                    spacing: 6px;
                                    LineEdit { text <=> root.watch-type; placeholder-text: "activitypub_actor"; horizontal-stretch: 1; }
                                    LineEdit { text <=> root.watch-cadence; placeholder-text: "minutes"; width: 70px; }
                                }
                                LineEdit { text <=> root.watch-target; placeholder-text: "Watch target"; }
                                LineEdit { text <=> root.watch-title; placeholder-text: "Watch title"; }
                                LineEdit { text <=> root.bundle-follow-target; placeholder-text: "Follow target to review"; }
                                Button {
                                    text: "Add Watch";
                                    clicked => {
                                        root.add-watch(root.watch-type, root.watch-target, root.watch-title, root.watch-cadence);
                                    }
                                }
                                Button {
                                    text: "Save bundle";
                                    clicked => {
                                        root.save-source-bundle(root.source-type, root.source-url, root.source-title, root.source-cadence, root.watch-target, root.watch-title, root.bundle-follow-target);
                                    }
                                }
                            }
                        }

                        if root.active-screen == "audience" : Rectangle {
                            min-height: 250px;
                            border-radius: 7px;
                            border-width: 1px;
                            border-color: #d9dee6;
                            background: #ffffff;

                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 7px;
                                    Text { text: "Audience group"; font-weight: 800; font-size: 13px; color: #172033; }
                                LineEdit { text <=> root.audience-id; placeholder-text: "id, blank for new"; }
                                LineEdit { text <=> root.audience-name; placeholder-text: "name"; }
                                LineEdit { text <=> root.audience-description; placeholder-text: "description"; }
                                HorizontalLayout {
                                    spacing: 7px;
                                    ComboBox {
                                        model: ["audience", "private_group"];
                                        current-index: root.audience-group-type == "private_group" ? 1 : 0;
                                        selected(option) => {
                                            root.audience-group-type = option;
                                        }
                                    }
                                    ComboBox {
                                        model: ["private", "members", "public"];
                                        current-index: root.audience-membership-visibility == "public" ? 2 : root.audience-membership-visibility == "members" ? 1 : 0;
                                        selected(option) => {
                                            root.audience-membership-visibility = option;
                                        }
                                    }
                                    ComboBox {
                                        model: ["owner", "members"];
                                        current-index: root.audience-posting-policy == "members" ? 1 : 0;
                                        selected(option) => {
                                            root.audience-posting-policy = option;
                                        }
                                    }
                                }
                                LineEdit { text <=> root.audience-categories; placeholder-text: "sensitive categories"; }
                                TextEdit { text <=> root.audience-members; height: 58px; }
                                HorizontalLayout {
                                    spacing: 8px;
                                    Button {
                                        text: "Save group";
                                        clicked => {
                                            root.save-audience(root.audience-id, root.audience-name, root.audience-description, root.audience-group-type, root.audience-membership-visibility, root.audience-posting-policy, root.audience-categories, root.audience-members);
                                        }
                                    }
                                    Button {
                                        text: "Delete group";
                                        enabled: root.audience-id != "";
                                        clicked => {
                                            root.delete-audience(root.audience-id);
                                        }
                                    }
                                }
                            }
                        }

                                if root.active-screen == "identity" : Rectangle {
                                    min-height: 260px;
                                    border-radius: 7px;
                                    border-width: 1px;
                                    border-color: #d9dee6;
                            background: #ffffff;

                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 7px;
                                    Text { text: "Public identity"; font-weight: 800; font-size: 13px; color: #172033; }
                                LineEdit { text <=> root.profile-actor-type; placeholder-text: "actor type"; }
                                LineEdit { text <=> root.profile-display-name; placeholder-text: "display name"; }
                                TextEdit { text <=> root.profile-summary; height: 66px; }
                                LineEdit { text <=> root.profile-icon; placeholder-text: "icon URL"; }
                                LineEdit { text <=> root.profile-image; placeholder-text: "header image URL"; }
                                Rectangle {
                                    min-height: 58px;
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: #d9dee6;
                                    background: #f7f8fb;
                                    Text {
                                        x: 9px;
                                        y: 7px;
                                        width: parent.width - 18px;
                                        text: root.profile-preview;
                                        font-size: 12px;
                                        color: #4a5568;
                                        wrap: word-wrap;
                                    }
                                }
                                HorizontalLayout {
                                    spacing: 6px;
                                    Button {
                                        text: "Preview public identity";
                                        clicked => {
                                            root.preview-profile(root.profile-actor-type, root.profile-display-name, root.profile-summary, root.profile-icon, root.profile-image);
                                        }
                                    }
                                    Button {
                                        text: "Save profile";
                                        clicked => {
                                            root.save-profile(root.profile-actor-type, root.profile-display-name, root.profile-summary, root.profile-icon, root.profile-image);
                                        }
                                    }
                                }
                            }
                        }

                        if root.active-screen == "moderation" : Rectangle {
                            min-height: 250px;
                            border-radius: 7px;
                            border-width: 1px;
                            border-color: #d9dee6;
                            background: #ffffff;

                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 7px;
                                    Text { text: "Moderation policy"; font-weight: 800; font-size: 13px; color: #172033; }
                                    HorizontalLayout {
                                    spacing: 6px;
                                    LineEdit { text <=> root.moderation-reply-policy; placeholder-text: "reply policy"; horizontal-stretch: 1; }
                                    LineEdit { text <=> root.moderation-ai-budget; placeholder-text: "AI budget"; width: 82px; }
                                }
                                LineEdit { text <=> root.moderation-ai-model; placeholder-text: "AI model"; }
                                CheckBox { text: "AI advisory"; checked <=> root.moderation-ai-enabled; }
                                Button {
                                    text: "Save policy";
                                    clicked => {
                                        root.save-moderation(root.moderation-reply-policy, root.moderation-ai-enabled, root.moderation-ai-model, root.moderation-ai-budget);
                                    }
                                }
                                LineEdit { text <=> root.moderation-block-actor; placeholder-text: "Actor to block"; }
                                LineEdit { text <=> root.moderation-block-domain; placeholder-text: "Domain to block"; }
                                LineEdit { text <=> root.moderation-block-reason; placeholder-text: "Reason"; }
                                HorizontalLayout {
                                    spacing: 8px;
                                    Button { text: "Block actor"; clicked => { root.block-actor(root.moderation-block-actor, root.moderation-block-reason); } }
                                    Button { text: "Block domain"; clicked => { root.block-domain(root.moderation-block-domain, root.moderation-block-reason); } }
                                }
                            }
                        }

                        if root.active-screen == "blocks" : Rectangle {
                            min-height: 174px;
                            border-radius: 7px;
                            border-width: 1px;
                            border-color: #d9dee6;
                            background: #ffffff;

                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 7px;
                                    Text { text: "Allowlist host"; font-weight: 800; font-size: 13px; color: #172033; }
                                LineEdit { text <=> root.moderation-allow-host; placeholder-text: "host"; }
                                LineEdit { text <=> root.moderation-allow-note; placeholder-text: "note"; }
                                HorizontalLayout {
                                    spacing: 8px;
                                    Button { text: "Allow host"; clicked => { root.allow-host(root.moderation-allow-host, root.moderation-allow-note); } }
                                    Button { text: "Remove host"; clicked => { root.disallow-host(root.moderation-allow-host); } }
                                }
                            }
                        }

                        if root.active-screen == "settings" : Rectangle {
                            min-height: 242px;
                            border-radius: 7px;
                            border-width: 1px;
                            border-color: #d9dee6;
                            background: #ffffff;

                            VerticalLayout {
                                padding: 10px;
                                spacing: 8px;
                                Text { text: "Owner defaults"; font-weight: 800; font-size: 13px; color: #172033; }
                                HorizontalLayout {
                                    spacing: 8px;
                                    LineEdit {
                                        text <=> root.settings-default-visibility;
                                        placeholder-text: "followers, public, unlisted, direct";
                                        horizontal-stretch: 1;
                                    }
                                    LineEdit {
                                        text <=> root.settings-default-protocol;
                                        placeholder-text: "activitypub, bluesky, both";
                                        horizontal-stretch: 1;
                                    }
                                }
                                CheckBox { text: "Require authorized fetch"; checked <=> root.settings-require-authorized-fetch; }
                                CheckBox { text: "Approve followers manually"; checked <=> root.settings-manually-approves-followers; }
                                CheckBox { text: "Closed network"; checked <=> root.settings-closed-network; }
                                Button {
                                    text: "Save defaults";
                                    clicked => {
                                        root.save-settings(root.settings-default-visibility, root.settings-default-protocol, root.settings-require-authorized-fetch, root.settings-manually-approves-followers, root.settings-closed-network);
                                    }
                                }
                            }
                        }

                        if root.active-screen == "accounts" : Rectangle {
                            min-height: 188px;
                            border-radius: 7px;
                            border-width: 1px;
                            border-color: #d9dee6;
                            background: #ffffff;

                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 8px;
                                    Text { text: "Account profile"; font-weight: 800; font-size: 13px; }
                                LineEdit { text <=> root.account-label; placeholder-text: "Label"; }
                                LineEdit { text <=> root.account-url; placeholder-text: "Instance URL"; }
                                LineEdit { text <=> root.account-token; placeholder-text: "Owner token"; }
                                Button {
                                    text: "Save account";
                                    clicked => {
                                        root.save-account(root.account-label, root.account-url, root.account-token);
                                    }
                                }
                            }
                        }

                        if root.active-screen == "accounts" : ScrollView {
                            height: 172px;
                            VerticalLayout {
                                spacing: 8px;
                                for account in accounts : Rectangle {
                                    min-height: 72px;
                                    border-radius: 6px;
                                    background: account.active ? #eef6ff : #ffffff;
                                    border-width: 1px;
                                    border-color: account.active ? #7aa5d8 : #d9dee6;

                                    VerticalLayout {
                                        padding: 8px;
                                        spacing: 5px;
                                        Text { text: account.title; font-weight: 800; color: #172033; overflow: elide; }
                                        Text { text: account.subtitle; color: #5b6676; font-size: 11px; overflow: elide; }
                                        HorizontalLayout {
                                            spacing: 8px;
                                            Button { text: "Switch"; enabled: !account.active; clicked => { root.switch-account(account.id); } }
                                            Button { text: "Delete"; enabled: account.can_delete; clicked => { root.delete-account(account.id); } }
                                        }
                                    }
                                }
                            }
                        }

                        ScrollView {
                            vertical-stretch: 1;
                            viewport-height: 470px;
                            VerticalLayout {
                                spacing: 10px;
                                for row in inspector-rows : InspectorRow {
                                    entry: row;
                                    action(id, action) => {
                                        root.row-action(id, action);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

}
